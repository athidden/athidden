{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "sort-imports": ["warn", { "ignoreDeclarationSort": true, "ignoreMemberSort": false }],
    "no-await-in-loop": "off"
  }
}
