{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",

  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",

  "sortPackageJson": false,

  "sortImports": {
    "newlinesBetween": true,
    "groups": ["builtin", "atcute", "athidden", "external", ["parent", "sibling", "index"]],
    "customGroups": [
      {
        "groupName": "atcute",
        "elementNamePattern": ["@atcute/**"]
      },
      {
        "groupName": "athidden",
        "elementNamePattern": ["@athidden/**"]
      }
    ]
  }
}
